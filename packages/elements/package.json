{
  "name": "@jects/elements",
  "version": "0.0.0",
  "description": "Jects UI Web Components — light-DOM custom elements over the framework-agnostic @jects/* engines. One generic factory, per-component typed element classes (config in, engine events out as CustomEvents, .instance for imperative access).",
  "license": "UNLICENSED",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/elements.js",
      "require": "./dist/elements.umd.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "module": "./dist/elements.js",
  "main": "./dist/elements.umd.cjs",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "@jects/core": "workspace:*",
    "@jects/grid": "workspace:*",
    "@jects/gantt": "workspace:*",
    "@jects/scheduler": "workspace:*",
    "@jects/calendar": "workspace:*",
    "@jects/kanban": "workspace:*",
    "@jects/todo": "workspace:*",
    "@jects/charts": "workspace:*",
    "@jects/diagram": "workspace:*",
    "@jects/spreadsheet": "workspace:*",
    "@jects/pivot": "workspace:*",
    "@jects/booking": "workspace:*",
    "@jects/chatbot": "workspace:*",
    "@jects/widgets": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@jects/grid": { "optional": true },
    "@jects/gantt": { "optional": true },
    "@jects/scheduler": { "optional": true },
    "@jects/calendar": { "optional": true },
    "@jects/kanban": { "optional": true },
    "@jects/todo": { "optional": true },
    "@jects/charts": { "optional": true },
    "@jects/diagram": { "optional": true },
    "@jects/spreadsheet": { "optional": true },
    "@jects/pivot": { "optional": true },
    "@jects/booking": { "optional": true },
    "@jects/chatbot": { "optional": true },
    "@jects/widgets": { "optional": true }
  },
  "devDependencies": {
    "@jects/core": "workspace:*",
    "@jects/grid": "workspace:*",
    "@jects/gantt": "workspace:*",
    "@jects/scheduler": "workspace:*",
    "@jects/calendar": "workspace:*",
    "@jects/kanban": "workspace:*",
    "@jects/todo": "workspace:*",
    "@jects/charts": "workspace:*",
    "@jects/diagram": "workspace:*",
    "@jects/spreadsheet": "workspace:*",
    "@jects/pivot": "workspace:*",
    "@jects/booking": "workspace:*",
    "@jects/chatbot": "workspace:*",
    "@jects/widgets": "workspace:*",
    "@jects/vite-config": "workspace:*",
    "jsdom": "^25.0.1",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^2.1.8"
  }
}
