{
  "name": "@jects/widgets",
  "version": "0.0.0",
  "description": "Jects UI widgets — the enterprise widget kit: fields, choice, date/time, pickers, display, feedback, forms, layout, navigation, overlays, windows, rich text, tabs, and data views.",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/widgets.js",
      "require": "./dist/widgets.umd.cjs"
    },
    "./forms": {
      "types": "./dist/forms.d.ts",
      "import": "./dist/forms.js"
    },
    "./overlays": {
      "types": "./dist/overlays.d.ts",
      "import": "./dist/overlays.js"
    },
    "./rich-text": {
      "types": "./dist/rich-text.d.ts",
      "import": "./dist/rich-text.js"
    },
    "./fields": {
      "types": "./dist/fields.d.ts",
      "import": "./dist/fields.js"
    },
    "./nav": {
      "types": "./dist/nav.d.ts",
      "import": "./dist/nav.js"
    },
    "./layout": {
      "types": "./dist/layout.d.ts",
      "import": "./dist/layout.js"
    },
    "./datetime": {
      "types": "./dist/datetime.d.ts",
      "import": "./dist/datetime.js"
    },
    "./pickers": {
      "types": "./dist/pickers.d.ts",
      "import": "./dist/pickers.js"
    },
    "./data-views": {
      "types": "./dist/data-views.d.ts",
      "import": "./dist/data-views.js"
    },
    "./style.css": "./dist/style.css"
  },
  "types": "./dist/index.d.ts",
  "module": "./dist/widgets.js",
  "main": "./dist/widgets.umd.cjs",
  "scripts": {
    "build": "vite build --config vite.config.umd.ts && vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "@jects/core": "workspace:*",
    "@jects/icons": "workspace:*",
    "@jects/theme": "workspace:*"
  },
  "devDependencies": {
    "@jects/core": "workspace:*",
    "@jects/icons": "workspace:*",
    "@jects/theme": "workspace:*",
    "@jects/vite-config": "workspace:*",
    "@vitest/browser": "^2.1.8",
    "axe-core": "^4.10.0",
    "playwright": "^1.49.1",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^2.1.8"
  }
}
