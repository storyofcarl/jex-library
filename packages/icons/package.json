{
  "name": "@jects/icons",
  "version": "0.8.0",
  "description": "Jects UI icons — tree-shakeable inline SVG set plus a sprite and render helpers.",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/icons.js",
      "require": "./dist/icons.umd.cjs"
    },
    "./sprite.svg": "./dist/sprite.svg"
  },
  "types": "./dist/index.d.ts",
  "module": "./dist/icons.js",
  "main": "./dist/icons.umd.cjs",
  "scripts": {
    "build": "node scripts/build-sprite.mjs && vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@jects/vite-config": "workspace:*",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^2.1.8"
  },
  "homepage": "https://jexlibrary.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/storyofcarl/jex-library.git",
    "directory": "packages/icons"
  },
  "bugs": {
    "url": "https://github.com/storyofcarl/jex-library/issues"
  },
  "keywords": [
    "jects",
    "jects-ui",
    "typescript",
    "enterprise-ui",
    "framework-agnostic",
    "icons",
    "svg",
    "icon-set"
  ],
  "engines": {
    "node": ">=20.17"
  }
}
