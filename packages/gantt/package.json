{
  "name": "@jects/gantt",
  "version": "0.8.0",
  "description": "Jects UI Gantt — task tree, dependencies, baselines, critical path, resource histogram, undo/redo, and PDF/PNG/CSV/XLSX/ICS/MS-Project (MSPDI) export.",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/gantt.js",
      "require": "./dist/gantt.umd.cjs"
    },
    "./engine": {
      "types": "./dist/engine/index.d.ts",
      "import": "./dist/engine.js"
    },
    "./export": {
      "types": "./dist/export/index.d.ts",
      "import": "./dist/export.js"
    },
    "./io": {
      "types": "./dist/io/index.d.ts",
      "import": "./dist/io.js"
    },
    "./resource": {
      "types": "./dist/resource/index.d.ts",
      "import": "./dist/resource.js"
    },
    "./style.css": "./dist/style.css"
  },
  "types": "./dist/index.d.ts",
  "module": "./dist/gantt.js",
  "main": "./dist/gantt.umd.cjs",
  "scripts": {
    "build": "vite build && vite build --config vite.subpaths.config.ts",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "@jects/core": "workspace:*",
    "@jects/timeline-core": "workspace:*",
    "@jects/grid": "workspace:*",
    "@jects/widgets": "workspace:*",
    "@jects/theme": "workspace:*"
  },
  "devDependencies": {
    "@jects/core": "workspace:*",
    "@jects/timeline-core": "workspace:*",
    "@jects/grid": "workspace:*",
    "@jects/widgets": "workspace:*",
    "@jects/theme": "workspace:*",
    "@jects/vite-config": "workspace:*",
    "@vitest/browser": "^2.1.8",
    "axe-core": "^4.10.0",
    "playwright": "^1.49.1",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^2.1.8"
  },
  "homepage": "https://jexlibrary.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/storyofcarl/jex-library.git",
    "directory": "packages/gantt"
  },
  "bugs": {
    "url": "https://github.com/storyofcarl/jex-library/issues"
  },
  "keywords": [
    "jects",
    "jects-ui",
    "typescript",
    "enterprise-ui",
    "framework-agnostic",
    "gantt",
    "project-management",
    "scheduling",
    "critical-path",
    "msproject"
  ],
  "engines": {
    "node": ">=20.17"
  }
}
