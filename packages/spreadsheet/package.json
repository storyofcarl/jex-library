{
  "name": "@jects/spreadsheet",
  "version": "0.0.0",
  "description": "Jects UI spreadsheet — a formula-driven workbook with validation, conditional formatting, named ranges, comments, embedded charts, fill-handle, protection, and XLSX import/export.",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/spreadsheet.js",
      "require": "./dist/spreadsheet.umd.cjs"
    },
    "./engine": {
      "types": "./dist/entry-engine.d.ts",
      "import": "./dist/engine.js"
    },
    "./io": {
      "types": "./dist/entry-io.d.ts",
      "import": "./dist/io.js"
    },
    "./style.css": "./dist/style.css"
  },
  "types": "./dist/index.d.ts",
  "module": "./dist/spreadsheet.js",
  "main": "./dist/spreadsheet.umd.cjs",
  "scripts": {
    "build": "vite build && vite build --mode subpaths",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "@jects/core": "workspace:*",
    "@jects/grid": "workspace:*",
    "@jects/widgets": "workspace:*",
    "@jects/charts": "workspace:*",
    "@jects/theme": "workspace:*"
  },
  "devDependencies": {
    "@jects/core": "workspace:*",
    "@jects/grid": "workspace:*",
    "@jects/widgets": "workspace:*",
    "@jects/charts": "workspace:*",
    "@jects/theme": "workspace:*",
    "@jects/vite-config": "workspace:*",
    "@vitest/browser": "^2.1.8",
    "axe-core": "^4.10.0",
    "playwright": "^1.49.1",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^2.1.8"
  }
}
