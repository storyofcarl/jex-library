{
  "name": "@jects/todo",
  "version": "0.8.0",
  "description": "Jects UI tasks — an enterprise task manager with List/Board/Calendar/Timeline/Table views, workflow statuses, comments, time tracking, dependencies, subtasks, recurrence, and import/export.",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/todo.js",
      "require": "./dist/todo.umd.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "types": "./dist/index.d.ts",
  "module": "./dist/todo.js",
  "main": "./dist/todo.umd.cjs",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "@jects/core": "workspace:*",
    "@jects/icons": "workspace:*",
    "@jects/theme": "workspace:*",
    "@jects/widgets": "workspace:*"
  },
  "devDependencies": {
    "@jects/core": "workspace:*",
    "@jects/icons": "workspace:*",
    "@jects/theme": "workspace:*",
    "@jects/widgets": "workspace:*",
    "@jects/vite-config": "workspace:*",
    "@vitest/browser": "^2.1.8",
    "axe-core": "^4.10.0",
    "playwright": "^1.49.1",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^2.1.8"
  },
  "homepage": "https://jexlibrary.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/storyofcarl/jex-library.git",
    "directory": "packages/todo"
  },
  "bugs": {
    "url": "https://github.com/storyofcarl/jex-library/issues"
  },
  "keywords": [
    "jects",
    "jects-ui",
    "typescript",
    "enterprise-ui",
    "framework-agnostic",
    "todo",
    "task-manager",
    "project-management",
    "workflow"
  ],
  "engines": {
    "node": ">=20.17"
  }
}
