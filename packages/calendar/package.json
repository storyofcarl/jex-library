{
  "name": "@jects/calendar",
  "version": "0.8.0",
  "description": "Jects UI calendar — day/week/month/year/agenda/resource/timeline views with RRULE recurrence, timezones, a modal event editor, undo/redo, and ICS/Excel/print export.",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/calendar.js",
      "require": "./dist/calendar.umd.cjs"
    },
    "./recurrence": {
      "types": "./dist/recurrence/index.d.ts",
      "import": "./dist/recurrence.js"
    },
    "./timezone": {
      "types": "./dist/timezone/index.d.ts",
      "import": "./dist/timezone.js"
    },
    "./export": {
      "types": "./dist/export/index.d.ts",
      "import": "./dist/export.js"
    },
    "./editor": {
      "types": "./dist/editor/index.d.ts",
      "import": "./dist/editor.js"
    },
    "./style.css": "./dist/style.css"
  },
  "types": "./dist/index.d.ts",
  "module": "./dist/calendar.js",
  "main": "./dist/calendar.umd.cjs",
  "scripts": {
    "build": "vite build && vite build --config vite.subpaths.config.ts",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "@jects/core": "workspace:*",
    "@jects/widgets": "workspace:*",
    "@jects/theme": "workspace:*"
  },
  "devDependencies": {
    "@jects/core": "workspace:*",
    "@jects/widgets": "workspace:*",
    "@jects/theme": "workspace:*",
    "@jects/vite-config": "workspace:*",
    "@vitest/browser": "^2.1.8",
    "axe-core": "^4.10.0",
    "playwright": "^1.49.1",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^2.1.8"
  },
  "homepage": "https://jexlibrary.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/storyofcarl/jex-library.git",
    "directory": "packages/calendar"
  },
  "bugs": {
    "url": "https://github.com/storyofcarl/jex-library/issues"
  },
  "keywords": [
    "jects",
    "jects-ui",
    "typescript",
    "enterprise-ui",
    "framework-agnostic",
    "calendar",
    "fullcalendar",
    "events",
    "recurrence",
    "rrule"
  ],
  "engines": {
    "node": ">=20.17"
  }
}
