{
  "name": "@jects/angular",
  "version": "0.0.0",
  "description": "Jects UI Angular wrapper — thin, typed Angular 17+ standalone bindings over the framework-agnostic @jects/* engines. One generic factory, per-component typed exports (config in, typed jectsEvent out, instance getter for imperative access). Engines run outside the Angular zone.",
  "license": "UNLICENSED",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "tsc -p tsconfig.spec.json --noEmit",
    "test:runtime": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
