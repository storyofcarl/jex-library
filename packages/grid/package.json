{
  "name": "@jects/grid",
  "version": "0.8.0",
  "description": "Jects UI data grid — a virtualized, enterprise-grade grid with typed columns, sort/filter, grouping, selection, inline editing, master-detail, tree mode, and CSV/Excel/PDF export.",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/grid.js",
      "require": "./dist/grid.umd.cjs"
    },
    "./engine": {
      "types": "./dist/engine/index.d.ts",
      "import": "./dist/engine.js"
    },
    "./columns": {
      "types": "./dist/columns/index.d.ts",
      "import": "./dist/columns.js"
    },
    "./features": {
      "types": "./dist/features/index.d.ts",
      "import": "./dist/features.js"
    },
    "./header-groups": {
      "types": "./dist/header-groups/index.d.ts",
      "import": "./dist/header-groups.js"
    },
    "./style.css": "./dist/style.css"
  },
  "types": "./dist/index.d.ts",
  "module": "./dist/grid.js",
  "main": "./dist/grid.umd.cjs",
  "scripts": {
    "build": "vite build && vite build --config vite.umd.config.ts && node -e \"require('fs').rmSync('dist/_umd-style-discard.css',{force:true})\"",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "@jects/core": "workspace:*",
    "@jects/theme": "workspace:*",
    "@jects/widgets": "workspace:*"
  },
  "devDependencies": {
    "@jects/core": "workspace:*",
    "@jects/theme": "workspace:*",
    "@jects/widgets": "workspace:*",
    "@jects/vite-config": "workspace:*",
    "@vitest/browser": "^2.1.8",
    "axe-core": "^4.10.0",
    "playwright": "^1.49.1",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^2.1.8"
  },
  "homepage": "https://jexlibrary.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/storyofcarl/jex-library.git",
    "directory": "packages/grid"
  },
  "bugs": {
    "url": "https://github.com/storyofcarl/jex-library/issues"
  },
  "keywords": [
    "jects",
    "jects-ui",
    "typescript",
    "enterprise-ui",
    "framework-agnostic",
    "data-grid",
    "grid",
    "table",
    "virtual-scroll",
    "datagrid"
  ],
  "engines": {
    "node": ">=20.17"
  }
}
