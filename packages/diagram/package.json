{
  "name": "@jects/diagram",
  "version": "0.8.0",
  "description": "Jects UI diagram — diagramming with built-in/custom/HTML/image shapes, A*-routed connectors, auto-layout, swimlanes, groups, undo/redo, and JSON/PNG/PDF export.",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/diagram.js",
      "require": "./dist/diagram.umd.cjs"
    },
    "./engine": {
      "types": "./dist/engine/index.d.ts",
      "import": "./dist/engine.js"
    },
    "./export": {
      "types": "./dist/ui/export.d.ts",
      "import": "./dist/export.js"
    },
    "./layout": {
      "types": "./dist/engine/layout.d.ts",
      "import": "./dist/layout.js"
    },
    "./shapes": {
      "types": "./dist/engine/shapes.d.ts",
      "import": "./dist/shapes.js"
    },
    "./style.css": "./dist/style.css"
  },
  "types": "./dist/index.d.ts",
  "module": "./dist/diagram.js",
  "main": "./dist/diagram.umd.cjs",
  "scripts": {
    "build": "vite build && vite build --config vite.subpaths.config.ts",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "@jects/core": "workspace:*",
    "@jects/theme": "workspace:*",
    "@jects/widgets": "workspace:*"
  },
  "devDependencies": {
    "@jects/core": "workspace:*",
    "@jects/theme": "workspace:*",
    "@jects/widgets": "workspace:*",
    "@jects/vite-config": "workspace:*",
    "@vitest/browser": "^2.1.8",
    "axe-core": "^4.10.0",
    "playwright": "^1.49.1",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^2.1.8"
  },
  "homepage": "https://jexlibrary.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/storyofcarl/jex-library.git",
    "directory": "packages/diagram"
  },
  "bugs": {
    "url": "https://github.com/storyofcarl/jex-library/issues"
  },
  "keywords": [
    "jects",
    "jects-ui",
    "typescript",
    "enterprise-ui",
    "framework-agnostic",
    "diagram",
    "flowchart",
    "graph",
    "connectors",
    "auto-layout"
  ],
  "engines": {
    "node": ">=20.17"
  }
}
