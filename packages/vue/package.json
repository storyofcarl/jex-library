{
  "name": "@jects/vue",
  "version": "0.0.0",
  "description": "Jects UI Vue 3 wrapper — thin, typed Vue bindings over the framework-agnostic @jects/* engines. One generic factory, per-component typed exports (props in, on* events out, expose() for imperative access).",
  "license": "UNLICENSED",
  "type": "module",
