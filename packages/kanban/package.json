{
  "name": "@jects/kanban",
  "version": "0.8.0",
  "description": "Jects UI kanban — a task board with swimlanes, WIP limits, rich cards, drag-and-drop, undo/redo, sort/filter, a data provider, and json/csv/png export.",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/kanban.js",
      "require": "./dist/kanban.umd.cjs"
    },
    "./editor": {
      "types": "./dist/editor/index.d.ts",
      "import": "./dist/editor.js"
    },
    "./data-provider": {
      "types": "./dist/data-provider/index.d.ts",
      "import": "./dist/data-provider.js"
    },
    "./style.css": "./dist/style.css"
  },
  "types": "./dist/index.d.ts",
  "module": "./dist/kanban.js",
  "main": "./dist/kanban.umd.cjs",
  "scripts": {
    "build": "vite build && vite build --config vite.subpaths.config.ts",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "@jects/core": "workspace:*",
    "@jects/widgets": "workspace:*",
    "@jects/theme": "workspace:*"
  },
  "devDependencies": {
    "@jects/core": "workspace:*",
    "@jects/widgets": "workspace:*",
    "@jects/theme": "workspace:*",
    "@jects/vite-config": "workspace:*",
    "@vitest/browser": "^2.1.8",
    "axe-core": "^4.10.0",
    "playwright": "^1.49.1",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^2.1.8"
  },
  "homepage": "https://jexlibrary.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/storyofcarl/jex-library.git",
    "directory": "packages/kanban"
  },
  "bugs": {
    "url": "https://github.com/storyofcarl/jex-library/issues"
  },
  "keywords": [
    "jects",
    "jects-ui",
    "typescript",
    "enterprise-ui",
    "framework-agnostic",
    "kanban",
    "task-board",
    "drag-and-drop",
    "swimlanes"
  ],
  "engines": {
    "node": ">=20.17"
  }
}
