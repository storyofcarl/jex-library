{
  "name": "@jects/tokens",
  "version": "0.8.0",
  "description": "Jects UI design tokens — the OKLCH 3-tier source of truth (primitive → semantic → component) emitted to CSS variables, SCSS maps, and TypeScript types.",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./tokens.scss": "./dist/tokens.scss",
    "./tokens.json": "./src/tokens.json"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "node scripts/build-tokens.mjs && tsc -p tsconfig.json",
    "dev": "node scripts/build-tokens.mjs",
    "test": "node scripts/build-tokens.mjs && node --test test/tokens.test.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint scripts"
  },
  "homepage": "https://jexlibrary.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/storyofcarl/jex-library.git",
    "directory": "packages/tokens"
  },
  "bugs": {
    "url": "https://github.com/storyofcarl/jex-library/issues"
  },
  "keywords": [
    "jects",
    "jects-ui",
    "typescript",
    "enterprise-ui",
    "framework-agnostic",
    "design-tokens",
    "oklch",
    "theming",
    "css-variables"
  ],
  "engines": {
    "node": ">=20.17"
  }
}
