{
  "name": "@jects/react",
  "version": "0.8.0",
  "description": "Jects UI React wrapper — thin, typed React bindings over the framework-agnostic @jects/* engines. One generic factory, per-component typed exports (props in, on* events out, ref for imperative access).",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
