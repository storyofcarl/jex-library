{
  "name": "@jects/core",
  "version": "0.8.0",
  "description": "Jects UI core — the zero-dependency engine powering the suite: signals, Widget base, Store/TreeStore, typed EventEmitter, DOM utilities, virtualization, and the component factory. Framework-free.",
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.umd.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "module": "./dist/core.js",
  "main": "./dist/core.umd.cjs",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@jects/vite-config": "workspace:*",
    "jsdom": "^25.0.1",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^2.1.8"
  },
  "homepage": "https://jexlibrary.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/storyofcarl/jex-library.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/storyofcarl/jex-library/issues"
  },
  "keywords": [
    "jects",
    "jects-ui",
    "typescript",
    "enterprise-ui",
    "framework-agnostic",
    "widget",
    "store",
    "signals",
    "virtualization",
    "zero-dependency"
  ],
  "engines": {
    "node": ">=20.17"
  }
}
