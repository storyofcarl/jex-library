{
  "name": "@jects/scheduler",
  "version": "0.0.0",
  "description": "Jects UI scheduler — multi-resource time-grid scheduling with time ranges, recurrence, travel-time and buffers, pan/infinite-scroll, and export.",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/scheduler.js",
      "require": "./dist/scheduler.umd.cjs"
    },
    "./export": {
      "types": "./dist/export/index.d.ts",
      "import": "./dist/export.js"
    },
    "./pro": {
      "types": "./dist/pro/index.d.ts",
      "import": "./dist/pro.js"
    },
    "./model": {
      "types": "./dist/model/index.d.ts",
      "import": "./dist/model.js"
    },
    "./recurrence": {
      "types": "./dist/recurrence.d.ts",
      "import": "./dist/recurrence.js"
    },
    "./style.css": "./dist/style.css"
  },
  "types": "./dist/index.d.ts",
  "module": "./dist/scheduler.js",
  "main": "./dist/scheduler.umd.cjs",
  "scripts": {
    "build": "vite build && vite build --config vite.umd.config.ts",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "@jects/core": "workspace:*",
    "@jects/timeline-core": "workspace:*",
    "@jects/grid": "workspace:*",
    "@jects/widgets": "workspace:*",
    "@jects/theme": "workspace:*"
  },
  "devDependencies": {
    "@jects/core": "workspace:*",
    "@jects/timeline-core": "workspace:*",
    "@jects/grid": "workspace:*",
    "@jects/widgets": "workspace:*",
    "@jects/theme": "workspace:*",
    "@jects/vite-config": "workspace:*",
    "@vitest/browser": "^2.1.8",
    "axe-core": "^4.10.0",
    "playwright": "^1.49.1",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^2.1.8"
  }
}
