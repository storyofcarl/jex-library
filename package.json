{
  "name": "jects-ui",
  "version": "0.0.0",
  "private": true,
  "description": "Jects UI — framework-agnostic JS/TS component library (Bryntum + DHTMLX replica).",
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=20.17"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "customizer": "pnpm --filter @jects/customizer dev",
    "docs": "pnpm --filter @jects/docs-app dev",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md}\"",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "matrix": "node scripts/gen-matrix.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "@eslint/js": "^9.17.0",
    "typescript-eslint": "^8.18.1",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^2.1.8",
    "@vitest/browser": "^2.1.8",
    "playwright": "^1.49.1"
  }
}
