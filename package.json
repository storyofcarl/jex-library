{
  "name": "jects-ui",
  "version": "0.0.0",
  "private": true,
  "description": "Jects UI — a framework-agnostic enterprise planning and data UI suite (grids, scheduling, Gantt, dashboards, diagrams, spreadsheets, forms, productivity).",
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=20.17"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "customizer": "pnpm --filter @jects/customizer dev",
    "docs": "pnpm --filter @jects/docs-app dev",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md}\"",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "matrix": "node scripts/gen-matrix.mjs",
    "bench": "node scripts/bench/run.mjs",
    "security:html": "node scripts/check-html-safety.mjs",
    "visual": "node scripts/visual-smoke.mjs",
    "a11y:routes": "node scripts/a11y-routes.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@vitest/browser": "^2.1.8",
    "axe-core": "^4.12.1",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^15.14.0",
    "playwright": "^1.49.1",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vite": "^6.0.5",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^2.1.8"
  }
}
